[Unit]
Description=Vnotice CVE Monitoring Backend (FastAPI / uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/vnotice/vnotice/backend
ExecStart=/home/vnotice/vnotice/backend/venv_server/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=append:/home/vnotice/backend.log
StandardError=append:/home/vnotice/backend.log

[Install]
WantedBy=default.target
