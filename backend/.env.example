# ──────────────────────────────────────────────────────────────────
# CVE Monitoring App – Backend Environment Configuration
# ──────────────────────────────────────────────────────────────────

# Database
# For local dev (SQLite, no Docker needed):
DATABASE_URL=sqlite:///./cvedb.sqlite

# For production (PostgreSQL via Docker Compose):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cvedb

# JWT Auth
SECRET_KEY=changeme-super-secret-jwt-key-32chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
